# Copy to .env (or set in the environment) to enable the guarded LLM layer.
# The application is fully functional WITHOUT this key: when absent, the
# classification/normalization/explanation layer uses a deterministic
# rule-based fallback. The LLM NEVER produces monetary amounts in either mode.
ANTHROPIC_API_KEY=

# Model used when the key is present.
CASHCONTROL_LLM_MODEL=claude-opus-4-8

# Path to the SQLite database file (defaults to ./data/cashcontrol.db).
CASHCONTROL_DB_PATH=

# Currency code shown in the UI/reports (data is single-currency ARS by design).
CASHCONTROL_CURRENCY=ARS

# Optional libSQL/Turso backend. When both are set the app uses Turso instead of
# local SQLite (same schema). Leave empty to use local SQLite.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Set to 0 for a real, start-empty install (no sample data auto-loaded).
CASHCONTROL_AUTOSEED=
